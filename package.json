{
  "name": "lipyum-partner-design-studio",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "find src tests -name '*.js' -print0 2>/dev/null | xargs -0 -r -n1 node_modules/node/bin/node --check",
    "lint": "find src tests -name '*.js' -print0 2>/dev/null | xargs -0 -r -n1 node_modules/node/bin/node --check",
    "test": "node_modules/node/bin/node --test tests/unit/*.test.js && node_modules/node/bin/node tests/routes.smoke.js",
    "test:unit": "node_modules/node/bin/node --test tests/unit/*.test.js",
    "test:e2e": "node_modules/node/bin/node node_modules/@playwright/test/cli.js test tests/e2e/routes.spec.js tests/e2e/back-button.spec.js tests/e2e/accessibility.spec.js",
    "test:e2e:mobile": "node_modules/node/bin/node node_modules/@playwright/test/cli.js test tests/e2e/mobile.spec.js",
    "test:screenshots": "node_modules/node/bin/node node_modules/@playwright/test/cli.js test tests/e2e/screenshots.spec.js",
    "test:routes": "node_modules/node/bin/node tests/routes.smoke.js",
    "test:accessibility": "node_modules/node/bin/node node_modules/@playwright/test/cli.js test tests/e2e/accessibility.spec.js",
    "build": "node_modules/node/bin/node node_modules/vite/bin/vite.js build",
    "dev": "node_modules/node/bin/node node_modules/vite/bin/vite.js --host 0.0.0.0",
    "preview": "node_modules/node/bin/node node_modules/vite/bin/vite.js preview --host 0.0.0.0"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.46.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "autoprefixer": "^10.5.0",
    "axe-core": "^4.12.1",
    "node": "^20.19.5",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "lucide-vue-next": "^1.0.0",
    "vue": "^3.5.38"
  }
}
